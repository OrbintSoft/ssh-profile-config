# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell scripts and Makefiles are tab-indented (Makefiles require it).
[*.{sh,zsh}]
indent_style = tab

[Makefile]
indent_style = tab

# Go is gofmt-formatted with tabs.
[*.go]
indent_style = tab

# Markdown uses trailing spaces for hard line breaks; its indentation is
# content-driven (list-marker alignment, fenced code), so don't enforce it.
[*.md]
trim_trailing_whitespace = false
indent_style = unset
indent_size = unset
